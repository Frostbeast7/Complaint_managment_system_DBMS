@page "{id:int}"
@model Sem_project.Pages.Complaints.DeleteModel

@{
    ViewData["Title"] = "Delete Complaint";
}

<h2>Delete Complaint</h2>

@if (Model.Complaint == null)
{
    <div class="alert alert-warning">Complaint not found.</div>
}
else
{
    <div class="mb-3">
        <h4>Complaint details</h4>
        <dl class="row">
            <dt class="col-sm-2">ID</dt>
            <dd class="col-sm-10">@Model.Complaint.Complaint_ID</dd>

            <dt class="col-sm-2">Description</dt>
            <dd class="col-sm-10">@Model.Complaint.Description</dd>

            <dt class="col-sm-2">Date</dt>
            <dd class="col-sm-10">@Model.Complaint.Date.ToShortDateString()</dd>

            <dt class="col-sm-2">Status</dt>
            <dd class="col-sm-10">@Model.Complaint.Status</dd>

            <dt class="col-sm-2">Student ID</dt>
            <dd class="col-sm-10">@Model.Complaint.Student_ID</dd>

            <dt class="col-sm-2">Category ID</dt>
            <dd class="col-sm-10">@Model.Complaint.Category_ID</dd>
        </dl>

        <form method="post">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
}
