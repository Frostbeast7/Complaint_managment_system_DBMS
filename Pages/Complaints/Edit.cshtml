@page "{id:int}"
@model Sem_project.Pages.Complaints.EditModel

@{
    ViewData["Title"] = "Edit Complaint";
}

<h2>Edit Complaint</h2>

<form method="post">
    <input asp-for="Complaint.Complaint_ID" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Complaint.Description" class="form-label"></label>
        <textarea asp-for="Complaint.Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Complaint.Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Complaint.Date" class="form-label"></label>
        <input asp-for="Complaint.Date" class="form-control" type="date" />
        <span asp-validation-for="Complaint.Date" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Complaint.Status" class="form-label"></label>
        <input asp-for="Complaint.Status" class="form-control" />
        <span asp-validation-for="Complaint.Status" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Complaint.Student_ID" class="form-label"></label>
        <input asp-for="Complaint.Student_ID" class="form-control" />
        <span asp-validation-for="Complaint.Student_ID" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Complaint.Category_ID" class="form-label"></label>
        <input asp-for="Complaint.Category_ID" class="form-control" />
        <span asp-validation-for="Complaint.Category_ID" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
