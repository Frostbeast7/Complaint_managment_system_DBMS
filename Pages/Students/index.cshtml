@page
@model Sem_project.Pages.Students.IndexModel

<h2>Students</h2>

<a asp-page="Create" class="btn btn-primary mb-3">Add Student</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Dept ID</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var s in Model.StudentsList)
{
        <tr>
            <td>@s.Student_ID</td>
            <td>@s.Name</td>
            <td>@s.Email</td>
            <td>@s.Phone</td>
            <td>@s.Dept_ID</td>
            <td>
                <a asp-page="Edit" asp-route-id="@s.Student_ID" class="btn btn-sm btn-warning">Edit</a>
                <a asp-page="Delete" asp-route-id="@s.Student_ID" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>