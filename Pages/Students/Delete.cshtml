@page "{id:int}"
@model Sem_project.Pages.Students.DeleteModel

@{
    ViewData["Title"] = "Delete Student";
}

<h2>Delete Student</h2>

@if (Model.Student == null)
{
    <div class="alert alert-warning">Student not found.</div>
}
else
{
    <div class="mb-3">
        <h4>Student details</h4>
        <dl class="row">
            <dt class="col-sm-2">ID</dt>
            <dd class="col-sm-10">@Model.Student.Student_ID</dd>

            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@Model.Student.Name</dd>

            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@Model.Student.Email</dd>

            <dt class="col-sm-2">Phone</dt>
            <dd class="col-sm-10">@Model.Student.Phone</dd>

            <dt class="col-sm-2">Dept ID</dt>
            <dd class="col-sm-10">@Model.Student.Dept_ID</dd>
        </dl>

        <form method="post">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
}
